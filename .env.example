# Session start only
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://nextasia.app.n8n.cloud/webhook/8a64212f-6788-4811-9e79-04e304162749

# Event processing: session_start, comment, gift, transcript_block
NEXT_PUBLIC_N8N_PROCESS_WEBHOOK_URL=https://nextasia.app.n8n.cloud/webhook/your-process-webhook-id

# TikTok session cookie (server-side only — required for reliable WebSocket connection)
TIKTOK_SESSION_ID=

# OpenAI API key (Realtime transcription + Whisper fallback)
OPENAI_API_KEY=

# Optional: FFmpeg path when /usr/bin/ffmpeg is unavailable (local dev)
# FFMPEG_PATH=/usr/local/bin/ffmpeg
